{
  "name": "spanner-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Google Cloud Spanner with natural language querying",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@google-cloud/spanner": "^6.0.0",
    "@modelcontextprotocol/sdk": "^0.4.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0",
    "dotenv": "^16.3.0",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "jest": "^29.5.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0"
  },
  "keywords": [
    "mcp",
    "spanner",
    "google-cloud",
    "natural-language",
    "sql",
    "database"
  ],
  "author": "Your Name",
  "license": "MIT"
} 